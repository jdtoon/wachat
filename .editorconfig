root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go: tabs (gofmt's choice), enforced by `make check`.
[*.go]
indent_style = tab

# Makefile: tabs are mandatory for recipe lines.
[Makefile]
indent_style = tab

# Markdown, YAML, JSON, TOML: 2-space soft indentation.
[*.{md,yml,yaml,json,toml}]
indent_style = space
indent_size = 2

# SQL and shell scripts.
[*.{sql,sh}]
indent_style = space
indent_size = 4
